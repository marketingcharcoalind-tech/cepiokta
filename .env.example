# === MODE ===
MODE=readonly                  # readonly | backtest | paper | live
LIVE_CONFIRMED=no              # MUST be 'yes' for live mode

# === WALLET / CHAIN (SECRET — do not commit real values!) ===
POLYGON_RPC_URL=                # primary RPC (mis. chainstack)
POLYGON_RPC_FALLBACKS=https://polygon-bor-rpc.publicnode.com,https://polygon-mainnet.public.blastapi.io,https://polygon.blockpi.network/v1/rpc/public  # cadangan (comma-separated; boleh kosong)
POLYGON_RPC_TIMEOUT_SECONDS=10  # timeout per request RPC (detik)


# === ENDPOINTS (verify latest versions!) ===
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_REST_URL=https://clob.polymarket.com
CLOB_WSS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market  # path WAJIB /ws/market (no trailing slash)
WS_APP_PING_SECONDS=10         # heartbeat aplikasi "PING" tiap N detik (server tak balas ping protokol)
WS_STALE_SECONDS=30            # tak ada pesan > N detik → tutup & reconnect
RESOLVE_POLL_SECONDS=30        # interval poll resolver (label outcome ronde yang sudah lewat)
CHAINLINK_BTCUSD_SOURCE=0xc907E116054Ad103354f2D350FD2514433D57F6f       # Chainlink BTC/USD feed (Polygon)
CHAINLINK_FEED_TYPE=data_feed  # data_feed (default) | data_stream (ditambah nanti)
CHAINLINK_MAX_STALENESS_SEC=120 # umur maks updatedAt (detik); > ini = stale → failover ke RPC berikutnya

# === RETENSI BOOK_SNAPSHOTS (Fase 1) ===
BOOK_PERSIST_MODE=changes      # changes = write-on-change + throttle | all = tulis semua (lama)
BOOK_SAMPLE_MS=1000            # bila best sama: maks 1 baris/token per N ms
BOOK_FINEGRAIN_SEC=45          # akhir-window: <= N detik → throttle OFF (resolusi penuh)
BOOK_DRAIN_SECONDS=3           # consume_market berhenti di window_end + N (tangkap settlement)
BOOK_POLL_SECONDS=1.0          # interval bangun loop saat senyap (cek deadline)
RECORDER_HEARTBEAT_SECONDS=15  # interval log heartbeat (visibilitas anti-freeze)

# === STRATEGY PARAMS (see docs/05) ===
T_ENTRY_SEC=20
DELTA_THRESHOLD=auto           # 'auto' = scale with volatility
MIN_PRICE=0.80
MAX_PRICE=0.99
MIN_EDGE=0.01
FLIP_RATIO=0.90
HEDGE_FRACTION=0.5
P_EXIT=0.65                    # hedge/exit when held-side p_win drops below this
FEE_RATE=0.07                  # crypto_fees_v2 taker base rate (verified)
FEE_EXPONENT=1                 # crypto_fees_v2: fee=rate*min(p,1-p)^exponent (verified)

# === SIZING & RISK (see docs/06) ===
BANKROLL_FLOOR=50
MAX_NOTIONAL_ROUND=5           # cap absolut $ per ronde (harus > 0)
MAX_BANKROLL_FRACTION=0.02     # cap 2% bankroll per ronde (0 < f <= 1)
FILL_SAFETY=0.8                # cap likuiditas: fraksi depth yang boleh disapu (0 < f <= 1)
MAX_OPEN_EXPOSURE=10
MAX_DAILY_LOSS_PCT=5
MAX_CONSEC_LOSSES=5
KELLY_FRACTION=0.25            # quarter-Kelly (0 < f <= 1); JANGAN full-Kelly
MAX_ORDERS_PER_MIN=30
STALE_MS=1500

# === PAPER TRADING ===
PAPER_TRADING=true             # true = simulasi (tanpa order nyata, tanpa private key)
PAPER_STARTING_BALANCE=200     # saldo virtual awal (= niat modal live); harus > 0

# === INFRA ===
DB_URL=sqlite+aiosqlite:///./btcbot.db
LOG_LEVEL=INFO

# === TELEGRAM (see docs/12) ===
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=            # SECRET — from @BotFather
TELEGRAM_ALLOWED_CHAT_IDS=     # Whitelist (comma-separated)
TELEGRAM_NOTIFY_CHAT_ID=
TELEGRAM_PER_ROUND_NOTIFY=true
TELEGRAM_HEARTBEAT_MIN=30
TELEGRAM_DAILY_SUMMARY=true

# === MULTI-MARKET (see docs/14) ===
MARKETS_CONFIG=./markets.yaml
MAX_OPEN_EXPOSURE_MARKET=10
MAX_OPEN_EXPOSURE_ASSET=15
MAX_CORRELATED_DIRECTIONAL=20
MAX_OPEN_EXPOSURE_GLOBAL=30
CHAINLINK_ETHUSD_SOURCE=0xF9680D99D6C9589e2a93a78A04A279e509205945
CHAINLINK_SOLUSD_SOURCE=0x10C8264C0935b3B9870013e057f330Ff3e9C56dC

